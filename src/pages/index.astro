---
import '../styles/global.css';
import { gifts } from '../data/gifts';

const notifyEndpoint = import.meta.env.PUBLIC_NOTIFY_ENDPOINT ?? '';
const pageTitle = 'Wedding Catalogue Gift';
const description = 'ウェディングギフトを選ぶための小さなカタログサイトです。';
const giftConfigJson = JSON.stringify({ notifyEndpoint });
const tilts = ['-1.4deg', '0.9deg', '-0.7deg', '1.1deg', '-1deg', '0.6deg', '-0.9deg', '1.3deg', '-0.5deg'];
---

<!doctype html>
<html lang="ja" class="fonts-loading">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow,noarchive" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      id="webfont-stylesheet"
      href="https://fonts.googleapis.com/css2?family=Mochiy+Pop+P+One&family=Yomogi&family=Zen+Maru+Gothic:wght@400;500;700;900&display=block"
      rel="stylesheet"
    />
    <style>
      html.fonts-loading .font-gated {
        display: none !important;
        visibility: hidden !important;
        opacity: 0 !important;
      }

      #font-loader {
        position: fixed;
        inset: 0;
        z-index: 70;
        display: grid;
        place-items: center;
        background: linear-gradient(180deg, #9ed2f2 0%, #fff3f8 100%);
      }
    </style>
    <title>{pageTitle}</title>
  </head>
  <body>
    <div id="font-loader" class="font-loader fixed inset-0 z-[70] bg-[linear-gradient(180deg,#9ed2f2_0%,#fff3f8_100%)]" aria-hidden="true"></div>

    <main class="font-gated relative min-h-screen overflow-hidden bg-[linear-gradient(180deg,#9ed2f2_0%,#d8ddf4_38%,#fff3f8_100%)] px-4 py-6 text-slate-800 sm:px-6 lg:px-8">
      <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        <div class="floating-petal left-[6%] top-[9%] rotate-[-18deg]"></div>
        <div class="floating-petal left-[86%] top-[12%] rotate-[22deg] delay-2"></div>
        <div class="floating-petal left-[12%] top-[70%] rotate-[12deg] delay-4"></div>
        <div class="floating-petal left-[76%] top-[67%] rotate-[-28deg] delay-3"></div>
        <div class="sparkle-field sparkle-field-one"></div>
        <div class="sparkle-field sparkle-field-two"></div>
        <div class="line-flower line-flower-left"></div>
        <div class="line-flower line-flower-right"></div>
      </div>

      <section class="relative mx-auto flex max-w-6xl flex-col items-center">
        <header class="mb-6 mt-4 text-center sm:mb-9 sm:mt-7">
          <p class="mb-2 text-sm font-bold tracking-[0.22em] text-sky-800/70 sm:text-base">AKARI WEDDING</p>
          <h1 class="catalogue-title text-[2.15rem] leading-tight text-sky-950 sm:text-[3.35rem] lg:text-[4.25rem]">
            Wedding Catalogue Gift
          </h1>
          <p class="note-title mt-4 text-xl text-slate-700 sm:text-3xl">あかり結婚おめでとう！！</p>
        </header>

        <section class="catalogue-sheet grid w-full grid-cols-1 gap-x-5 gap-y-9 sm:grid-cols-2 lg:grid-cols-3 lg:gap-x-7 lg:gap-y-12" aria-label="ギフト一覧">
          {
            gifts.map((gift, index) => (
              <article
                class="gift-card group relative flex min-h-[410px] flex-col items-center"
                style={`--reveal-delay: ${index * 70}ms; --tilt: ${tilts[index % tilts.length]}`}
              >
                <button
                  type="button"
                  class="gift-button gift-paper flex w-full flex-1 flex-col items-center border border-white/70 bg-[#fffdf8]/88 p-3 text-center shadow-[0_18px_38px_rgba(86,72,92,0.13)] transition duration-300 hover:-translate-y-1 hover:bg-white hover:shadow-[0_24px_48px_rgba(86,72,92,0.18)] focus:outline-none focus-visible:border-pink-400 focus-visible:ring-4 focus-visible:ring-white/90"
                  data-gift-id={gift.id}
                  data-gift-name={gift.name}
                  data-gift-message={gift.message}
                  data-gift-image={gift.image}
                >
                  <span class="masking-tape" aria-hidden="true"></span>
                  <span class="relative block w-full overflow-hidden bg-[#f8f5ef]">
                    <img
                      src={gift.image}
                      alt={`${gift.name}のイラスト`}
                      class="aspect-square w-full object-cover transition duration-500 group-hover:scale-[1.018]"
                      loading={index < 3 ? 'eager' : 'lazy'}
                      decoding="async"
                    />
                    <span class="selected-ribbon absolute right-3 top-3 rounded-full bg-pink-100/95 px-3 py-1 text-xs font-bold text-pink-700 opacity-0 shadow-sm transition">
                      選択中
                    </span>
                  </span>
                  <span class="gift-name mt-4 block text-[1.65rem] leading-tight text-slate-800 sm:text-[1.9rem]">
                    {gift.name}
                  </span>
                  <span class="gift-message mt-3 block min-h-[3.4rem] max-w-[18rem] text-balance text-lg leading-relaxed text-slate-700 sm:text-xl">
                    {gift.message}
                  </span>
                </button>
              </article>
            ))
          }
        </section>
      </section>
    </main>

    <div id="confirm-modal" class="font-gated fixed inset-0 z-50 hidden items-center justify-center overflow-y-auto bg-sky-950/30 px-4 py-6 backdrop-blur-[2px]" aria-hidden="true">
      <section class="modal-panel gift-detail-modal w-full max-w-[28rem] bg-[#fffdf8] p-4 shadow-[0_24px_80px_rgba(74,57,72,0.24)] sm:p-5" role="dialog" aria-modal="true" aria-labelledby="modal-title">
        <div class="mb-3 flex items-start justify-between gap-4">
          <div>
            <p class="text-sm font-bold tracking-[0.18em] text-pink-500">GIFT SELECT</p>
            <h2 id="modal-title" class="modal-title mt-1 text-2xl text-slate-900">このギフトでいい？</h2>
          </div>
          <button id="modal-close" type="button" class="grid h-10 w-10 place-items-center rounded-full border border-pink-100 bg-white text-2xl leading-none text-slate-500 transition hover:bg-pink-50 focus:outline-none focus-visible:ring-4 focus-visible:ring-pink-200" aria-label="閉じる">
            ×
          </button>
        </div>

        <div class="modal-gift-visual overflow-hidden rounded-[6px] border border-pink-100 bg-[#f8f5ef]">
          <img id="modal-gift-image" class="aspect-square w-full object-cover" src="" alt="" decoding="async" />
        </div>

        <div class="modal-gift-copy mt-4 rounded-[6px] border border-pink-100 bg-pink-50/60 p-4 text-center">
          <p id="modal-gift-name" class="gift-name text-3xl text-slate-900"></p>
          <p id="modal-gift-message" class="gift-message mt-3 text-xl leading-relaxed text-slate-700"></p>
        </div>
        <p id="modal-error" class="mt-4 hidden rounded-[6px] bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700"></p>
        <div class="modal-choice-actions mt-5 grid grid-cols-1 gap-3 sm:grid-cols-[1fr_1.3fr]">
          <button id="modal-cancel" type="button" class="rounded-full border border-pink-100 bg-white px-5 py-3 font-bold text-slate-600 transition hover:bg-pink-50 focus:outline-none focus-visible:ring-4 focus-visible:ring-pink-200">
            別のプレゼントを見る
          </button>
          <button id="modal-submit" type="button" class="rounded-full bg-[#ff8fb3] px-5 py-3 font-black text-white shadow-[0_14px_30px_rgba(255,143,179,0.34)] transition hover:-translate-y-0.5 hover:bg-[#f476a3] focus:outline-none focus-visible:ring-4 focus-visible:ring-pink-200">
            これを選ぶ！
          </button>
        </div>
      </section>
    </div>

    <div id="success-toast" class="font-gated fixed bottom-5 left-1/2 z-50 hidden w-[calc(100%-2rem)] max-w-lg -translate-x-1/2 rounded-[8px] border border-pink-100 bg-[#fffdf8] px-5 py-4 text-center text-base font-bold text-slate-800 shadow-[0_18px_60px_rgba(74,57,72,0.2)] sm:text-lg" role="status">
      選んでくれてありがとう！贈る側にお知らせしました。
    </div>

    <script type="application/json" id="gift-config" set:html={giftConfigJson}></script>
    <script>
      const fontLoader = document.getElementById('font-loader');
      const hideFontLoader = () => {
        document.documentElement.classList.remove('fonts-loading');
        document.documentElement.classList.add('fonts-ready');
        if (!fontLoader) return;
        fontLoader.classList.add('is-hidden');
        window.setTimeout(() => fontLoader.remove(), 420);
      };

      const waitForFonts = async () => {
        if (!('fonts' in document)) {
          hideFontLoader();
          return;
        }

        const fontStylesheet = document.getElementById('webfont-stylesheet');
        const stylesheetReady = new Promise((resolve, reject) => {
          if (!fontStylesheet) {
            resolve();
            return;
          }

          try {
            if (fontStylesheet.sheet) {
              resolve();
              return;
            }
          } catch {
            resolve();
            return;
          }

          fontStylesheet.addEventListener('load', resolve, { once: true });
          fontStylesheet.addEventListener('error', reject, { once: true });
        });

        await stylesheetReady;

        await Promise.all([
          document.fonts.load('400 32px "Mochiy Pop P One"'),
          document.fonts.load('400 24px "Yomogi"'),
          document.fonts.load('700 18px "Zen Maru Gothic"'),
          document.fonts.ready,
        ]);
        hideFontLoader();
      };

      waitForFonts().catch(() => {
        console.warn('Web fonts failed to load. Keeping the font gate visible to avoid layout shift.');
      });

      const configElement = document.getElementById('gift-config');
      const config = configElement ? JSON.parse(configElement.textContent || '{}') : {};
      const notifyEndpoint = config.notifyEndpoint || '';
      const buttons = Array.from(document.querySelectorAll('[data-gift-id]'));
      const modal = document.getElementById('confirm-modal');
      const modalGiftName = document.getElementById('modal-gift-name');
      const modalGiftMessage = document.getElementById('modal-gift-message');
      const modalGiftImage = document.getElementById('modal-gift-image');
      const modalClose = document.getElementById('modal-close');
      const modalCancel = document.getElementById('modal-cancel');
      const modalSubmit = document.getElementById('modal-submit');
      const modalError = document.getElementById('modal-error');
      const successToast = document.getElementById('success-toast');
      let selectedGift = null;
      let lastFocusedButton = null;
      let lockedScrollY = 0;

      const requestJsonp = (endpoint, params = {}) => new Promise((resolve, reject) => {
        if (!endpoint) {
          resolve(null);
          return;
        }

        let url;
        try {
          url = new URL(endpoint);
        } catch {
          reject(new Error('Invalid notification endpoint URL'));
          return;
        }

        const callbackName = `akariWeddingCallback_${Date.now()}_${Math.random().toString(36).slice(2)}`;
        Object.entries(params).forEach(([key, value]) => {
          url.searchParams.set(key, value);
        });
        url.searchParams.set('callback', callbackName);

        const script = document.createElement('script');
        const cleanup = () => {
          delete window[callbackName];
          script.remove();
          window.clearTimeout(timeoutId);
        };
        const timeoutId = window.setTimeout(() => {
          cleanup();
          reject(new Error('Selection status request timed out'));
        }, 8000);

        window[callbackName] = (payload) => {
          cleanup();
          resolve(payload);
        };
        script.onerror = () => {
          cleanup();
          reject(new Error('Selection status request failed'));
        };
        script.src = url.toString();
        document.body.appendChild(script);
      });

      const lockPageScroll = () => {
        lockedScrollY = window.scrollY;
        document.body.classList.add('modal-open');
        document.body.style.top = `-${lockedScrollY}px`;
      };

      const unlockPageScroll = () => {
        document.body.classList.remove('modal-open');
        document.body.style.top = '';
        window.scrollTo(0, lockedScrollY);
      };

      const showError = (message) => {
        if (!modalError) return;
        modalError.textContent = message;
        modalError.classList.remove('hidden');
      };

      const clearError = () => {
        if (!modalError) return;
        modalError.textContent = '';
        modalError.classList.add('hidden');
      };

      const openModal = (gift, trigger) => {
        selectedGift = gift;
        lastFocusedButton = trigger;
        if (modalGiftName) modalGiftName.textContent = gift.name;
        if (modalGiftMessage) modalGiftMessage.textContent = gift.message;
        if (modalGiftImage) {
          modalGiftImage.setAttribute('src', gift.image);
          modalGiftImage.setAttribute('alt', `${gift.name}のイラスト`);
        }
        clearError();
        modal?.classList.remove('hidden');
        modal?.classList.add('flex');
        modal?.setAttribute('aria-hidden', 'false');
        lockPageScroll();
        modalSubmit?.focus();
      };

      const closeModal = () => {
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
        modal?.setAttribute('aria-hidden', 'true');
        unlockPageScroll();
        clearError();
        lastFocusedButton?.focus();
      };

      const showSuccess = () => {
        if (!successToast) return;
        successToast.classList.remove('hidden');
        window.setTimeout(() => {
          successToast.classList.add('hidden');
        }, 6000);
      };

      const markSelected = (giftId) => {
        buttons.forEach((button) => {
          const isSelected = button.getAttribute('data-gift-id') === giftId;
          button.setAttribute('aria-pressed', String(isSelected));
          button.classList.toggle('is-selected', isSelected);
        });
        try {
          window.localStorage.setItem('akari-wedding:last-gift', giftId);
        } catch {
          // Local storage is only a convenience; ignore unavailable storage.
        }
      };

      const loadSharedSelection = async () => {
        if (!notifyEndpoint) {
          try {
            const localGiftId = window.localStorage.getItem('akari-wedding:last-gift');
            if (localGiftId) markSelected(localGiftId);
          } catch {
            // Local storage is only a convenience; ignore unavailable storage.
          }
          return;
        }

        try {
          const status = await requestJsonp(notifyEndpoint, { action: 'status' });
          const selectedGiftId = status?.selected?.giftId;
          if (selectedGiftId) markSelected(selectedGiftId);
        } catch (error) {
          console.warn('Failed to load shared gift selection status.', error);
        }
      };

      const sendNotification = async (gift) => {
        if (!notifyEndpoint) {
          await new Promise((resolve) => window.setTimeout(resolve, 450));
          return;
        }

        const payload = new URLSearchParams({
          giftId: gift.id,
          giftName: gift.name,
          giftMessage: gift.message,
          submittedAt: new Date().toISOString(),
        });

        await fetch(notifyEndpoint, {
          method: 'POST',
          mode: 'no-cors',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
          },
          body: payload,
        });
      };

      buttons.forEach((button) => {
        button.setAttribute('aria-pressed', 'false');
        button.addEventListener('click', () => {
          openModal(
            {
              id: button.getAttribute('data-gift-id'),
              name: button.getAttribute('data-gift-name'),
              message: button.getAttribute('data-gift-message'),
              image: button.getAttribute('data-gift-image'),
            },
            button,
          );
        });
      });

      loadSharedSelection();

      modalClose?.addEventListener('click', closeModal);
      modalCancel?.addEventListener('click', closeModal);
      modal?.addEventListener('click', (event) => {
        if (event.target === modal) closeModal();
      });
      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && modal?.classList.contains('flex')) closeModal();
      });

      modalSubmit?.addEventListener('click', async () => {
        if (!selectedGift || !modalSubmit) return;
        modalSubmit.setAttribute('disabled', 'true');
        modalSubmit.textContent = '送信中...';
        clearError();
        try {
          await sendNotification(selectedGift);
          markSelected(selectedGift.id);
          closeModal();
          showSuccess();
        } catch {
          showError('送信できませんでした。少し時間を置いてもう一度試してください。');
        } finally {
          modalSubmit.removeAttribute('disabled');
          modalSubmit.textContent = 'これを選ぶ！';
        }
      });
    </script>
  </body>
</html>
